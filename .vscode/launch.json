{
    "configurations": [
      
        {
            "name": "Containers: Api Launch",
            "type": "docker",
            "request": "launch",
            "preLaunchTask": "Baytib.Api docker-run: debug",
            "netCore": {
                "appProject": "${workspaceFolder}/src/Baytic.Api/Baytic.Api.csproj"
            }
        },
        {
            "name": "Docker Compose: Start Stack",
            "type": "node-terminal",
            "request": "launch",
            "preLaunchTask": "compose: up",
            "command": "start http://localhost:5003"
        },
    ]
}